generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubmissionStatus {
  PENDING
  UNDER_REVIEW
  REVIEWED
  ACCEPTED
  REJECTED
}

enum Decision {
  PASS
  FAIL
  HOLD
}

enum ReviewerRole {
  HR
  ADMIN
}

enum AuditAction {
  SUBMISSION_CREATED
  SUBMISSION_UPDATED
  REVIEW_ADDED
}

model Candidate {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  city         String
  privateToken String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions Submission[]
}

model AssessmentBrief {
  id          Int      @id @default(autoincrement())
  role        String
  title       String
  description String
  deadline    DateTime
  createdAt   DateTime @default(now())

  submissions Submission[]
}

model Submission {
  id                Int              @id @default(autoincrement())
  candidateId       Int
  assessmentBriefId Int
  workLink          String
  fileReference     String?
  timeTaken         Int
  notes             String?
  challenges        String?
  status            SubmissionStatus @default(PENDING)
  submittedAt       DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  candidate       Candidate       @relation(fields: [candidateId], references: [id])
  assessmentBrief AssessmentBrief @relation(fields: [assessmentBriefId], references: [id])
  review          Review?
  auditLogs       AuditLog[]

  @@unique([candidateId, assessmentBriefId])
  @@index([status])
  @@index([submittedAt])
}

model Review {
  id           Int      @id @default(autoincrement())
  submissionId Int      @unique
  reviewerId   Int
  score        Int
  decision     Decision
  privateNote  String?
  reviewedAt   DateTime @default(now())

  submission Submission   @relation(fields: [submissionId], references: [id])
  reviewer   ReviewerUser @relation(fields: [reviewerId], references: [id])
}

model ReviewerUser {
  id        Int          @id @default(autoincrement())
  email     String       @unique
  password  String
  role      ReviewerRole
  createdAt DateTime     @default(now())

  reviews Review[]
}

model AuditLog {
  id           Int         @id @default(autoincrement())
  submissionId Int
  action       AuditAction
  actor        String
  oldValue     Json?
  newValue     Json?
  createdAt    DateTime    @default(now())

  submission Submission @relation(fields: [submissionId], references: [id])
}
